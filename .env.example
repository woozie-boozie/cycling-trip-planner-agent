# Anthropic Claude — required
ANTHROPIC_API_KEY=sk-ant-...

# Model — defaults to claude-sonnet-4-5 if unset
ANTHROPIC_MODEL=claude-sonnet-4-5

# Database — Neon Postgres connection string (Phase 1.12a)
# Tool data (routes, accommodation, weather, elevation) lives here.
# Sessions will move here in Phase 1.12b.
# Local dev: leave empty to use SQLite in-memory (tests do this automatically).
DATABASE_URL=postgresql+asyncpg://neondb_owner:...@ep-...eu-west-2.aws.neon.tech/neondb?ssl=require

# Real API toggle (Phase 1.10) — set to "true" to fetch live climate norms
# from Open-Meteo's free Archive API (no API key required, no signup).
# Falls back to the DB mock on any failure, so the agent never breaks.
USE_REAL_WEATHER=false

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
