# Anthropic Claude — required
ANTHROPIC_API_KEY=sk-ant-...

# Model — defaults to claude-sonnet-4-5 if unset
ANTHROPIC_MODEL=claude-sonnet-4-5

# Database — Neon Postgres connection string (Phase 1.12a)
# Tool data (routes, accommodation, weather, elevation) lives here.
# Sessions will move here in Phase 1.12b.
# Local dev: leave empty to use SQLite in-memory (tests do this automatically).
DATABASE_URL=postgresql+asyncpg://neondb_owner:...@ep-...eu-west-2.aws.neon.tech/neondb?ssl=require

# Real API toggle (Phase 1.10) — set to "true" to fetch live climate norms
# from Open-Meteo's free Archive API (no API key required, no signup).
# Falls back to the DB mock on any failure, so the agent never breaks.
USE_REAL_WEATHER=false

# Real bike-routing via BRouter (Phase 1.10b) — free, no key needed.
# When true, get_route hits brouter.de for real OpenStreetMap cycling
# routes with multi-variant support. Falls back to seed on failure.
USE_REAL_ROUTES=false

# Real Places via Google Places API New (Phase 1.10d) — needs a key.
# When true, find_accommodation + get_points_of_interest pull from
# Google with real ratings, review counts, photos, and price tiers.
# Categories without a Places type (water_fountain, toilet) fall back
# to the seed catalog automatically. Free $200/mo Google credit covers
# case-study volume by orders of magnitude.
# Get a key: console.cloud.google.com → Places API (New) → Credentials
USE_REAL_PLACES=false
GOOGLE_PLACES_API_KEY=

# Logging
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
